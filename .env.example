# --- Billet integration (single source of truth) ---
# Base URL of the unit's Billet portal. Swap subdomain -> custom domain here only.
NEXT_PUBLIC_BILLET_BASE=https://ptf.billet.gg
# Unit slug the Billet API is addressed by.
NEXT_PUBLIC_BILLET_SLUG=ptf

# --- This site ---
# Public canonical URL of THIS site (used for metadata, sitemap, OG tags).
# Use the dev subdomain while testing, then paramarines.net when it goes live.
NEXT_PUBLIC_SITE_URL=https://paramarines.net
